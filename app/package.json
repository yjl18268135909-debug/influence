{
  "name": "shopfluence-live-management",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "client:dev": "vite",
    "server:dev": "nodemon server/index.js",
    "server:start": "node server/index.js",
    "start": "NODE_ENV=production node server/index.js",
    "migrate:prod": "node scripts/migrate-sqlite-to-postgres.js",
    "client:build": "tsc && vite build",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.0",
    "@supabase/supabase-js": "^2.106.1",
    "antd": "^5.15.3",
    "axios": "^1.6.7",
    "better-sqlite3": "^12.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dayjs": "^1.11.10",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "express": "^4.18.2",
    "lucide-react": "^1.16.0",
    "pg": "^8.21.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0",
    "@vitejs/plugin-react": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "@types/node": "^24.12.3",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/pg": "^8.20.0",
    "concurrently": "^8.2.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.0",
    "typescript-eslint": "^8.59.2"
  }
}
